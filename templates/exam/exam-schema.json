{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CSE463 per-student vision exam",
  "type": "object",
  "required": ["student_id", "student_name", "homework", "total_points", "questions"],
  "properties": {
    "student_id": {"type": "string", "description": "Öğrenci ID / klasör adı"},
    "student_name": {"type": "string", "description": "Öğrenci adı (bilinmiyorsa ID tekrar)"},
    "homework": {"type": "integer", "description": "Ödev numarası (1, 2, ...)"},
    "homework_title": {"type": "string", "description": "Ödevin kısa başlığı (opsiyonel)"},
    "duration_minutes": {"type": "integer", "default": 90},
    "total_points": {"type": "integer", "const": 100},
    "is_pair": {"type": "boolean", "default": false},
    "pair_partners": {"type": "array", "items": {"type": "string"}},
    "questions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["number", "title", "points", "category", "text", "expected_answer", "rubric"],
        "properties": {
          "number": {"type": "integer", "minimum": 1, "maximum": 4},
          "title": {"type": "string", "description": "Kısa soru başlığı"},
          "points": {"type": "integer", "const": 25},
          "category": {
            "type": "string",
            "enum": ["submission-specific", "general-cv"],
            "description": "submission-specific = öğrencinin kendi rapor/koduna dayalı; general-cv = standart CV kavramı"
          },
          "reference": {
            "type": "string",
            "description": "İlgili CV konusu/kaynak (örn. 'Convolution & filtering', 'Harris corners', 'Szeliski Ch.4')"
          },
          "text": {"type": "string", "description": "Soru metni (İngilizce)"},
          "code_excerpt": {
            "type": "string",
            "description": "Opsiyonel — öğrencinin kendi kodundan kısa bir alıntı (max ~15 satır), soru buna atıfta bulunur"
          },
          "expected_answer": {"type": "string", "description": "TA/AI için beklenen cevap (İngilizce)"},
          "rubric": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Puanları toplamı 25 olan rubric maddeleri"
          }
        }
      }
    }
  }
}
